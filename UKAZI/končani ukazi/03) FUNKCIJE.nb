Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Remove", "@", "newt"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"newt", " ", "=", " ", 
    RowBox[{"Compile", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"z", ",", " ", "_Complex", ",", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"n", ",", " ", "_Integer", ",", "0"}], "}"}]}], "}"}], ",", 
      " ", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"zn", " ", "=", " ", "z"}], "}"}], ",", "\n", "   ", "\n", 
        "   ", 
        RowBox[{
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{"zn", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", "zn"}], " ", "+", " ", 
               RowBox[{"1", "/", 
                RowBox[{"zn", "^", "2"}]}]}], ")"}], "/", "3"}]}], ",", " ", 
           RowBox[{"{", "n", "}"}]}], "]"}], ";", " ", "\n", "   ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Re", "[", "zn", "]"}], " ", ">", " ", "0"}], ",", " ", 
           "1", ",", " ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Im", "[", "zn", "]"}], " ", ">", " ", "0"}], ",", " ", 
             "2", ",", " ", "3"}], "]"}]}], "]"}]}]}], "]"}], ",", "\n", 
      "   ", "\n", "   ", 
      RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
      RowBox[{"\"\<RuntimeOptions\>\"", "->", "\"\<Speed\>\""}], ",", 
      RowBox[{"Parallelization", "->", "True"}]}], "\n", "]"}]}], ";"}], "\n",
   "\n"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{"sp", "=", 
    RowBox[{
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"newt", "[", 
        RowBox[{
         RowBox[{"x", "+", 
          RowBox[{"I", " ", "y"}]}], ",", "25"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "1"}], ",", "1", ",", 
         RowBox[{"2.", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"res", "[", 
             RowBox[{"[", "2", "]"}], "]"}], "-", "1"}], ")"}]}]}], "}"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "1", ",", 
         RowBox[{"2.", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"res", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "-", "1"}], ")"}]}]}], "}"}]}], 
      "]"}], "/", "3"}]}], ";"}], "]"}], "\n", 
