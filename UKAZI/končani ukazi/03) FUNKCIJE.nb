Cell[CellGroupData[{

Cell[TextData[{
 "Definirana funkcija ",
 StyleBox["MyModule",
  FontWeight->"Bold",
  FontSlant->"Italic"]
}], "Subitem",
 CellChangeTimes->{{3.8715489363114796`*^9, 3.8715489712072163`*^9}, {
  3.8715490153430276`*^9, 3.8715490900326643`*^9}, {3.871549187944213*^9, 
