Cell[CellGroupData[{

Cell["GLOBALNE IN LOKALNE SPREMENLJIVKE", "Title",
 CellChangeTimes->{{3.87031903876556*^9, 3.8703190407511487`*^9}, {
  3.870320410610295*^9, 
  3.8703204344106226`*^9}},ExpressionUUID->"5e706e06-3e50-4bec-8890-\
e8b3fd7ebf31"],

Cell[CellGroupData[{

Cell["\<\
Za razliko od Pythona je v Mathematici funkcija lahko uporablja zunanje \
globalne vrednosti. Tudi vse, kar se v funkciji nara\[CHacek]una postane \
globalno.\
\>", "Item",
 CellChangeTimes->{{3.870320471753047*^9, 3.870320510514723*^9}, {
  3.8703209950061426`*^9, 
  3.870321053422226*^9}},ExpressionUUID->"28fa0eb6-816f-430c-868c-\
c82de86cebb9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Remove", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"c", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
    RowBox[{"(", "\n", "\t", 
     RowBox[{
      RowBox[{"a", "=", 
       SuperscriptBox["x", "2"]}], ";", "\n", "\t", 
      RowBox[{"b", "=", 
       RowBox[{"x", "+", "y"}]}], ";", "\n", "\t", 
      RowBox[{
       RowBox[{"a", " ", "b"}], " ", "+", " ", "c"}]}], "\n", ")"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"f", "[", 
  RowBox[{"2", ",", "3"}], "]"}], "\n", "x", "\n", "a", "\n", "b"}], "Code",
 CellChangeTimes->{{3.870319413298753*^9, 3.8703194513425283`*^9}, {
