Cell[CellGroupData[{

Cell[TextData[{
 "Vseeno pa naslednje deluje.  ",
 StyleBox["x_",
  FontWeight->"Bold"],
 " ne pomeni globalne vrednosti spremenljivke ",
 StyleBox["x",
  FontWeight->"Bold"],
 ", ampak poljubno stvar (argument), na katero se znotraj f sklicujemo z x. \
To ima prednost pred globalno vrednostjo x.",
 " "
}], "Item",
