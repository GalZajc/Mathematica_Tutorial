4dd0c0e96cf8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "@", "MyModule"}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Attributes", "[", "MyModule", "]"}], " ", "=", " ", 
   RowBox[{"{", "HoldAll", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"MyModule", "[", "expr_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"{", " ", 
      RowBox[{"spec", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", "\n", "          ", 
         RowBox[{"Union", "[", " ", 
          RowBox[{"Join", " ", "@@", " ", 
           RowBox[{"Cases", "[", "\n", "              ", 
            RowBox[{
             RowBox[{"Hold", "[", "expr", "]"}], ",", "\n", "              ", 
             RowBox[{
              RowBox[{"s_Symbol", " ", "/;", " ", 
               RowBox[{
                RowBox[{"Context", "[", 
                 RowBox[{"Unevaluated", "[", "s", "]"}], "]"}], " ", "===", 
                " ", "\"\<Global`\>\""}]}], " ", ":>", " ", 
              RowBox[{"Hold", "[", "s", "]"}]}], ",", "\n", "             ", 
             RowBox[{"{", 
              RowBox[{"-", "1"}], "}"}], ",", "\n", "             ", 
             RowBox[{"Heads", " ", "->", " ", "False"}]}], "\n", "          ",
             "]"}]}], "]"}], "\n", "      ", ")"}], " ", "/.", " ", 
        RowBox[{
         RowBox[{"Hold", "[", "spec__", "]"}], " ", ":>", " ", 
         RowBox[{"Hold", "[", 
          RowBox[{"{", "spec", "}"}], "]"}]}]}]}], "\n", "    ", "}"}], ",", 
     "\n", "    ", 
     RowBox[{"Module", " ", "@@", " ", 
      RowBox[{"(", 
       RowBox[{"Hold", "[", 
        RowBox[{
         RowBox[{"Evaluate", "[", 
          RowBox[{"Unevaluated", " ", "@@", " ", "spec"}], "]"}], ",", " ", 
         "expr"}], "]"}], ")"}]}]}], "\n", "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.8715482568270807`*^9, 3.871548401393309*^9}, {
   3.871548434953123*^9, 3.871548566385598*^9}, {3.8715489939042697`*^9, 
   3.8715489963290744`*^9}, 
   3.871549224585747*^9},ExpressionUUID->"9cc11217-ad03-4ab9-b7d5-\
4ee8886c7f55"],

