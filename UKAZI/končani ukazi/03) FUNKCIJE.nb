Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"res", "=", 
   RowBox[{"{", 
    RowBox[{"1000", ",", "1000"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Remove", "@", "newt"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"newt", "[", 
     RowBox[{"z_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"zn", " ", "=", " ", "z"}], "}"}], ",", "\n", "   ", 
      RowBox[{
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"zn", " ", "=", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2.0", " ", "zn"}], " ", "+", " ", 
             SuperscriptBox["zn", 
              RowBox[{"-", "2.0"}]]}], ")"}], "/", "3"}]}], ",", " ", 
         RowBox[{"{", "n", "}"}]}], "]"}], ";", " ", "\n", "   ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Re", "[", "zn", "]"}], " ", ">", " ", "0"}], ",", " ", "1",
          ",", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Im", "[", "zn", "]"}], " ", ">", " ", "0"}], ",", " ", 
           "2", ",", " ", "3"}], "]"}]}], "]"}]}]}], "\n", "]"}]}], ";"}], 
  "\n", "\n"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{"sp", "=", 
    RowBox[{
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"newt", "[", 
        RowBox[{
         RowBox[{"x", "+", 
          RowBox[{"I", " ", "y"}]}], ",", "25"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "1"}], ",", "1", ",", 
         RowBox[{"2.", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"res", "[", 
             RowBox[{"[", "2", "]"}], "]"}], "-", "1"}], ")"}]}]}], "}"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "1", ",", 
         RowBox[{"2.", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"res", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "-", "1"}], ")"}]}]}], "}"}]}], 
      "]"}], "/", "3"}]}], ";"}], "]"}], "\n", 
 RowBox[{"Image", "@", "sp"}]}], "Code",
 CellChangeTimes->{{3.8708269921517115`*^9, 3.870826992153717*^9}, {
