Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x_", ",", " ", "y_"}], "]"}], " ", ":=", " ", 
    RowBox[{"MyModule", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"a", " ", "=", " ", "3"}], ";", " ", "\n", "\t", 
      RowBox[{"b", " ", "=", " ", "2"}], ";", " ", "\n", "\t", 
      RowBox[{"c", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", " ", "+", " ", "y"}], ")"}], "*", 
        RowBox[{"(", 
         RowBox[{"a", " ", "+", " ", "b"}], ")"}]}]}]}], "\n", "]"}]}], ";"}],
   "\n", "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "c"}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{"\"\<a\>\"", ",", "\"\<bb\>\"", ",", "\"\<ccc\>\""}], "}"}]}], 
   ";"}], "\n", "\n"}], "\n", 
 RowBox[{"f", "[", 
  RowBox[{"1", ",", " ", "2"}], 
  "]"}], "\n", "a", "\n", "b", "\n", "c"}], "Code",
 CellChangeTimes->{
