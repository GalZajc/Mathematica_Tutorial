atex verzija005\\_brezim verzija005\\_brezim.pdf","KEY_TYPE":"KEY_TEXT_WRITE"}],"BD":1,"C":[],"BE":-16776961,"kSCM":25,"BG":-16711936,"E":[],"kIAPBKC":-14803426,"I":"","ITS":true,"BiR":true,"kSCTY":0,"BiT":false,"kSCHS":false,"inS":"","IiS":false,"T":"pdf","kSCAC":-14145496,"kSCC":-4611631,"kSCHRC":false,"THO":4,"id":"u107kdv649dby","GUdata":"","kSCIUFATS":false,"kCT":1,"kSIP":0,"TELS":5,"kSCI":"","kIAs":[],"GUid":-1,"kSCIIVA":true,"COLS":1,"TA":5,"TC":-1,"kSVP":0,"kSTP":0,"kSVAC":-10575407,"TO":4,"TP":2,"inB":false,"kSD":0,"kSCTM":0,"TS":20,"inC":0,"ROWS":1},{},{},{"FF":"Default","A":[{"KEY_TEXT_TO_WRITE":"\\documentclass[12pt]{report}\n\n\\usepackage[scaled]{helvet}\n\\usepackage[T1]{fontenc}\n\\usepackage{lingmacros}\n\\usepackage{tree-dvips}\n\\usepackage{geometry}\n\\usepackage{multirow}\n\\usepackage{array}\n\\usepackage{amsmath}\n\\usepackage{cases}\n\\usepackage{graphicx}\n\\usepackage{float}\n\n\\setlength{\\parindent}{0em}\n\n\n\\geometry{\na4paper,\ntotal={170mm,257mm},\nleft=15mm,\ntop=20mm,\n}\n\\renewcommand\\familydefault{\\sfdefault}\n\\setlength\\arrayrulewidth{2pt}%    OSNOVNA DEBELINA CvRT V TABELAH\n\n\\newenvironment{rcases}\n{\\left.\\begin{aligned}}\n{\\end{aligned}\\right\\rbrace}\\graphicspath{{C:/Users/gal/Downloads/program za prisanje porocvil2/porocvila/naslov je lkamdsklf dkpfompcv sdkml lks.md/grafi/}}\n\\begin{document}\n\n\n\\vspace*{5cm}\n\n\\begin{center}\n{\\fontsize{50}{1}\\selectfont naslov je lkamdsklf dkpfompcv sdkml\\\n \nlks.md\\\\[3cm] }\n{\\fontsize{20}{1}\\selectfont \n\\textbf{datum vaje:}  1.januar.2020\\\\[1cm]\n\\textbf{avtor vaje:} gal zoidberg\\\\[1cm]\n\\textbf{sodelavci:} dvklmlkvkdv assfll\\\\[1cm]\n}\\end{center}\n\n\n\\newpage\n\n\n\\section*{\\\\1.) UVOD}\nuvod$\\sqrt[4]{\\left(\\frac{x}{a}\\right)^b}$je$2 \\pi  \\sqrt{\\frac{m}{k}}$takle\\\n \nseznam\n\\section*{2.) MERITVE}\n\n\n\n\n\n\\makeatletter\n\\def\\hlinewd#1{%\n\\noalign{\\ifnum0=`}\\fi\\hrule \\@height #1 \\futurelet\n\\reserved@a\\@xhline}\n\\makeatother\n\n\n\n\n\nV enacvbi $t=2 \\pi  n \\sqrt{\\frac{m}{k}}$ smo izmerili naslednje vrednosti\\\n \nkonstantnih spremenljivk:\\\\\n$n=10 \\pm 0.00001$\\\\\nSpreminjali pa smo $m$, ob cvemer se je spreminjal $t$. V spodnji tabeli so\\\n \nzbrane meritve $t(m)$.\\\\\n\\begin{table}[h]\n\\centering\n\\small\n\\begin{tabular}{|c|c|}\\hline\n$m[kg]$&$t[s]$ \\\\ \\hline$1\\pm0.1$&$1\\pm0.2$\\\\ \\hlinewd{.5pt}\n$2\\pm0.1$&$1.4\\pm0.2$\\\\ \\hlinewd{.5pt}\n$\n\\begin{rcases}\n2.8\\pm0.1\\\\\n2.9\\pm0.1\\\\\n3\\pm0.1\\\\\n3.1\\pm0.1\n\\end{rcases}\n3\\pm0.1\n$&$1.7\\pm0.2$\\\\ \\hlinewd{.5pt}\n$4\\pm0.1$&$2\\pm0.2$\\\\ \\hlinewd{.5pt}\n$5\\pm0.1$&$2.2\\pm0.2$\\\\ \\hlinewd{.5pt}\n$6\\pm0.1$&$2.4\\pm0.2$\\\\ \\hline\n\\end{tabular}\n\\end{table}\n\\\\[2cm]\nV enacvbi $a=\\frac{F}{m}$ nismo merili konstantnih spremenljivk. Spreminjali\\\n \npa smo $F$, ob cvemer se je spreminjal $a$. V spodnji tabeli so zbrane\\\n \nmeritve $a(F)$.\\\\\n\\begin{table}[h]\n\\centering\n\\small\n\\begin{tabular}{|c|c|}\\hline\n$F[N]$&$a[\\frac{m}{s^2}]$ \\\\ \\hline$4\\pm0.3$&$28\\pm0.08$\\\\ \\hlinewd{.5pt}\n$5\\pm0.3$&$35\\pm0.08$\\\\ \\hlinewd{.5pt}\n$6\\pm0.3$&$42\\pm0.08$\\\\ \\hlinewd{.5pt}\n$7\\pm0.3$&$49\\pm0.08$\\\\ \\hlinewd{.5pt}\n$8\\pm0.3$&$56\\pm0.08$\\\\ \\hlinewd{.5pt}\n$9\\pm0.3$&$61\\pm0.08$\\\\ \\hlinewd{.5pt}\n$10\\pm0.3$&$70\\pm0.08$\\\\ \\hlinewd{.5pt}\n$11\\pm0.3$&$77\\pm0.08$\\\\ \\hline\n\\end{tabular}\n\\end{table}\n\\\\[2cm]\n\n\\section*{3.) RACvUNI, GRAFI, REZULTATI}\n\nuvod$\\sqrt[4]{\\left(\\frac{x}{a}\\right)^b}$je$2 \\pi  \\sqrt{\\frac{m}{k}}$takle\\\n \nseznam\n\\newpage\n\nZ metodo minimalnih kvadratov dolocvimo $k$ v enacvbi $t=2 \\pi \\sqrt{\\frac{m}{k}}$ tako, da se graf enacvbe kar najbolje prilega\\\n \nmeritvam:\\\\\n$$k=3940\\frac{kg}{s^2}\\pm10\\frac{kg}{s^2}=3940\\frac{kg}{s^2}(1\\pm0.003)$$\\\\\nGraf $t(m)$ je na naslednji sliki:\\\\\n\\begin{figure}[H]\n\\includegraphics[width=\\linewidth]{grafm(t)}\n\\end{figure}\n\\newpage\n\n\nZ metodo minimalnih kvadratov dolocvimo $m$ v enacvbi $a=\\frac{F}{m}$ tako,\\\n \nda se graf enacvbe kar najbolje prilega meritvam:\\\\\n$$m=0.1436\\frac{N s^2}{m}\\pm0.0007\\frac{N s^2}{m}=0.1436\\frac{N\\\n \ns^2}{m}(1\\pm0.005)$$\\\\\nGraf $a(F)$ je na naslednji sliki:\\\\\n\\begin{figure}[H]\n\\includegraphics[width=\\linewidth]{grafF(a)}\n\\end{figure}\n\\newpage\n\n\n\n\\section*{4.) KOMENTAR}\n\nuvod$\\sqrt[4]{\\left(\\frac{x}{a}\\right)^b}$je$2 \\pi  \\sqrt{\\frac{m}{k}}$takle seznam\n\n\n\n\n\n\\end{document}\n","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_URL":"","KEY_TYPE":"OPEN_URL_ACTION"}],"BD":1,"C":[],"BE":-16711936,"kSCM":25,"BG":-16711936,"E":[],"kIAPBKC":-14803426,"I":"","ITS":true,"BiR":true,"kSCTY":0,"BiT":false,"kSCHS":false,"inS":"","IiS":false,"T":"PRIMER","kSCAC":-14145496,"kSCC":-4611631,"kSCHRC":false,"THO":4,"id":"u713hwz925upi","GUdata":"","kSCIUFATS":false,"kCT":1,"kSIP":0,"TELS":5,"kSCI":"","kIAs":[],"GUid":-1,"kSCIIVA":true,"COLS":1,"TA":5,"TC":-1,"kSVP":0,"kSTP":0,"kSVAC":-10575407,"TO":4,"TP":2,"inB":false,"kSD":0,"kSCTM":0,"TS":20,"inC":0,"ROWS":1},{"FF":"Default","A":[{"KEY_TEXT_TO_WRITE":"\\hat{}","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_KEYCODES":[37],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"}],"BD":1,"C":[],"BE":-256,"kSCM":25,"BG":-256,"E":[],"kIAPBKC":-14803426,"I":"","ITS":true,"BiR":true,"kSCTY":0,"BiT":false,"kSCHS":false,"inS":"","IiS":false,"T":"^","kSCAC":-14145496,"kSCC":-4611631,"kSCHRC":false,"THO":4,"id":"u182mnm270xtc","GUdata":"","kSCIUFATS":false,"kCT":1,"kSIP":0,"TELS":5,"kSCI":"","kIAs":[],"GUid":-1,"kSCIIVA":true,"COLS":1,"TA":5,"TC":-1,"kSVP":0,"kSTP":0,"kSVAC":-10575407,"TO":4,"TP":2,"inB":false,"kSD":0,"kSCTM":0,"TS":20,"inC":0,"ROWS":1},{},{"FF":"Default","A":[{"KEY_TEXT_TO_WRITE":"\\left|","KEY_TYPE":"KEY_TEXT_WRITE"}],"BD":1,"C":[],"BE":-16711936,"kSCM":25,"BG":-16711936,"E":[],"kIAPBKC":-14803426,"I":"","ITS":true,"BiR":true,"kSCTY":0,"BiT":false,"kSCHS":false,"inS":"","IiS":false,"T":"|","kSCAC":-14145496,"kSCC":-4611631,"kSCH