"","kSCIUFATS":false,"kCT":1,"kSIP":0,"TELS":5,"kSCI":"","kIAs":[],"GUid":-1,"kSCIIVA":true,"COLS":1,"TA":5,"TC":-1,"kSVP":0,"kSTP":0,"kSVAC":-10575407,"TO":4,"TP":2,"inB":false,"kSD":0,"kSCTM":0,"TS":20,"inC":0,"ROWS":1},{"FF":"Default","A":[{"KEY_TEXT_TO_WRITE":"Solve[{","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_KEYCODES":[10],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"},{"KEY_TEXT_TO_WRITE":"==,","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_KEYCODES":[10],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"},{"KEY_TEXT_TO_WRITE":"},","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_KEYCODES":[10],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"},{"KEY_TEXT_TO_WRITE":"{}]","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_KEYCODES":[38],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"},{"KEY_KEYCODES":[38],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"},{"KEY_KEYCODES":[39],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"}],"BD":1,"C":[],"BE":-1664691,"kSCM":25,"BG":-1684147,"E":[],"kIAPBKC":-14803426,"I":"","ITS":true,"BiR":true,"kSCTY":0,"BiT":false,"kSCHS":false,"inS":"","IiS":false,"T":"==","kSCAC":-14145496,"kSCC":-4611631,"kSCHRC":false,"THO":4,"id":"u139dpe257fzy","GUdata":"","kSCIUFATS":false,"kCT":1,"kSIP":0,"TELS":5,"kSCI":"","kIAs":[],"GUid":-1,"kSCIIVA":true,"COLS":1,"TA":5,"TC":-1,"kSVP":0,"kSTP":0,"kSVAC":-10575407,"TO":4,"TP":2,"inB":false,"kSD":0,"kSCTM":0,"TS":20,"inC":0,"ROWS":1},{"FF":"Default","A":[{"KEY_TEXT_TO_WRITE":"from wolframclient.evaluation import WolframLanguageSession\nfrom wolframclient.language import wl, wlexpr\nfrom manim import*\nimport PIL\nfrom PIL import Image\n#import bpy\nimport mcpi. minecraft as minecraft\nimport mcpi. block as block\n\nimport tkinter as tk\nimport math\nimport numpy as np\nfrom numpy import linalg as LA\nimport h5py\nimport scipy as scp\nimport pandas as pd\nimport os\nimport io\nimport zipfile\nimport time\nimport codecs\n\n\ndef h5_v_array(pot_h5_datoteke):\n    file = h5py.File(pot_h5_datoteke, 'r')\n    dataset = []\n    for i in file.values():\n        dataset.append(i)\n    return(np.array(dataset)[0])\ndef h5_v_tuple_array(pot_h5_datoteke):\n    return([[tuple(j) for j in i] for i in h5_v_array(pot_h5_datoteke)])\n\ndef Flatten(sez,nivo):\n    dim=sez.shape\n    return(np.reshape(\n        sez,\n        tuple([np.product(dim[:nivo+1])])+tuple(dim[nivo+1:])   \n        )   \n    )\n\ndef normalize(v):\n    normv = LA.norm(v)\n    if (normv == 0): \n        return (v)\n    else:\n        return (v/normv)\n\ndef vector_angle(v1, v2):\n    v1_u = normalize(v1)\n    v2_u = normalize(v2)\n    return np.arccos(np.clip(np.dot(v1_u, v2_u), -1.0, 1.0))\n\ndef normalni(oglišča):\n    trojice=np.array([[oglišča[i-2],oglišča[i-1],oglišča[i]] for i in np.arange(len(oglišča)) ])\n    return(normalize(np.sum([np.cross((trojica[2]-trojica[1]),(trojica[1]-trojica[0])) for trojica in trojice])))\n\ndef RM_v_fi(v, fi):\n    \"\"\"\n    Return the rotation matrix associated with counterclockwise rotation about\n    the given v by fi radians.\n    \"\"\"\n    v = np.asarray(v)\n    v = v / math.sqrt(np.dot(v, v))\n    a = math.cos(fi / 2.0)\n    b, c, d = -v * math.sin(fi / 2.0)\n    aa, bb, cc, dd = a * a, b * b, c * c, d * d\n    bc, ad, ac, ab, bd, cd = b * c, a * d, a * c, a * b, b * d, c * d\n    return np.array([[aa + bb - cc - dd, 2 * (bc + ad), 2 * (bd - ac)],\n                     [2 * (bc - ad), aa + cc - bb - dd, 2 * (cd + ab)],\n                     [2 * (bd + ac), 2 * (cd - ab), aa + dd - bb - cc]])\n\ndef RM_v1_v2_fi(v1,v2, fi):\n    RM_v_fi(np.cross(v1,v2), fi)\n    \ndef RM(arg1,arg2,arg3):\n    if (arg3==\"ne\"):\n        return(RM_v_fi(arg1, arg2))\n    else:\n        return(RM_v1_v2_fi(arg1,arg2,arg3))\n\n\n\ndef log(baza,št):\n    return(np.log(št)/np.log(baza))\n\n\n\n\ntabulator=\"    \"\n\ndef StringJoin(sez):\n    združen_str=\"\"\n    for i in sez:\n        združen_str+=i\n    return(združen_str)\n\ndef Table(arg):\n    črsp=[]   #črke spremenljivk\n    forstringi=[]\n    števc=0\n    \n#############################################\n    definicija_str=arg[0][1:-1]\n\n    for i in arg[1:]:\n        if (type(i) is list):\n            črsp+=[i[0]]\n            forstringi+=[\"for \"+i[0]+\" in np.arange(\"+StringJoin([str(i2)+\",\" for i2 in i[1:]])[:-1]+\")]\\n\" ]\n        else:\n            forstringi+=[\"for AS\"+str(števc)+\" in np.arange(\"+str(i)+\")]\\n\" ]     #Avtomatska Spremenljivka \n        števc+=1\n    črsp2=\"\"\n    for i in črsp:\n        črsp2+=i+\",\"    \n    črsp3=črsp2[:-1]\n    črsp3\n    forstringi2=StringJoin(forstringi)\n\n#############################################\n\n    združen_str=StringJoin([\n    \"def fzatable(\",\n    črsp3,\n\"\"\"\n):\n\n\"\"\"[1:-1],tabulator,\n    definicija_str.replace(\"\\n\", \"\\n\"+tabulator),\n    \"\\nTable_output=np.array(\",\n    (len(arg)-1)*\"[\",\n\"\"\"\n\nfzatable(\n\"\"\"[1:-1],črsp3,\")\\n\",\n    forstringi2,\n\"\"\"\n)\n\"\"\"[1:-1]\n    ])\n    \n#############################################\n    print(združen_str)\n#    exec(združen_str)\n#    eval(združen_str)\n#    return(Table_output)\n\ndef RGBvHEX(RGB):\n    return('#%02x%02x%02x' % tuple([min(int(i),255) for i in (np.round(255*np.array(RGB))).tolist()]))\n\n\npi=np.pi\ndeg=pi/180\nee=np.e","KEY_TYPE":"KEY_TEXT_WRITE"}],"BD":1,"C":[],"BE":-16711681,"kSCM":25,"BG":-16711681,"E":[],"kIAPBKC":-14803426,"I":"1616779474462.png","ITS":true,"BiR":true,"kSCTY":0,"BiT":false,"kSCHS":false,"inS":"","IiS":false,"T":"","kSCAC":-14145496,"kSCC":-4611631,"kSCHRC":false,"THO":4,"id":"u331oym960bht","GUdata":"","kSCIUFATS":false,"kCT":1,"kSIP":0,"TELS":5,"kSCI":"","kIAs":[],"GUid":-1,"kSCIIVA":true,"COLS":1,"TA":5,"TC":-65536,"kSVP":0,"kSTP":0,"kSVAC":-10575407,"TO":4,"TP":2,"inB":false,"kSD":0,"kSCTM":0,"TS":20,"inC":0,"ROWS":1}],[{"FF":"Default","A":[{"KEY_TEXT_TO_WRITE":"[for i1,i2 in zip(s1,s2) if]","KEY_TYPE":"KEY_TEXT_WRITE"},{"KEY_KEYCODES":[37],"KEY_DURATION":100,"KEY_TYPE":"KEY_PRESS_ACTION"}],"BD":1,"C":[],"BE":-5308416,"kSCM":25,"BG":