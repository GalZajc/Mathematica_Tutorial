Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sol", "=", 
    RowBox[{"NDSolve", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"y", "''"}], "[", "t", "]"}], " ", "==", " ", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"y", "[", "t", "]"}]}], " ", "-", " ", 
          RowBox[{".2", "*", 
           SuperscriptBox[
            RowBox[{"y", "[", "t", "]"}], "2"]}], " ", "+", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"0.2", "t"}], "]"}]}]}], ",", "        ", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "'"}], "[", "0", "]"}], "==", "0"}], ",", "        ", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", "\n", "\t", 
      "y", ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "300"}], "}"}]}], "\n", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sr", " ", "=", " ", "10"}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"Sample", " ", "Rate"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"y", "[", "t", "]"}], " ", "/.", " ", 
       RowBox[{"sol", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "300", ",", " ", 
       RowBox[{"1", "/", "sr"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"ListPlot", "@", "data"}]}], "Code",
 CellChangeTimes->{{3.869461830836629*^9, 3.8694618308376236`*^9}, {
