Cell[BoxData[{
 RowBox[{
  RowBox[{"Remove", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[SHacek]togl", "=", "100"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"tji", "=", 
   RowBox[{"Subdivide", "[", 
    RowBox[{"0", ",", 
     RowBox[{
      RowBox[{"N", "@", "2"}], "\[Pi]"}], ",", 
     RowBox[{"\[SHacek]togl", "-", "1"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rji", "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"2", 
         RowBox[{"Cos", "@", "tji"}]}], "+", 
        RowBox[{"Cos", "[", 
         RowBox[{"5", "tji"}], "]"}]}], ",", "   ", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"Sin", "@", "tji"}]}], "+", 
        RowBox[{"Sin", "[", 
         RowBox[{"5", "tji"}], "]"}]}]}], "}"}], "\[Transpose]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"ListPlot", "[", 
   RowBox[{"rji", ",", 
    RowBox[{"AspectRatio", "->", "Automatic"}]}], "]"}], "\n", "\n", "\n", 
  "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{"red", "=", "4"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[SHacek]togl2", "=", "500"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"to\[CHacek]keC", "=", 
   RowBox[{
    RowBox[{"rji", "[", 
     RowBox[{"[", 
      RowBox[{";;", ",", "1"}], "]"}], "]"}], "+", 
    RowBox[{
     RowBox[{"rji", "[", 
      RowBox[{"[", 
       RowBox[{";;", ",", "2"}], "]"}], "]"}], "\[ImaginaryI]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[SHacek]togl", "=", 
    RowBox[{"Length", "@", "to\[CHacek]keC"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"cji", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"Mean", "[", "#", "]"}], "&"}], "/@", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "1.0"}], 
           FractionBox[
            RowBox[{"n", " ", "2", "\[Pi]", " ", "\[ImaginaryI]", " ", "j"}], 
            "\[SHacek]togl"], " "}]], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{"-", "red"}], ",", "red"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "\[SHacek]togl"}], "}"}]}], "]"}], "*", 
       RowBox[{"Table", "[", 
        RowBox[{"to\[CHacek]keC", ",", 
         RowBox[{
          RowBox[{"2", "*", "red"}], "+", "1"}]}], "]"}]}], ")"}]}]}], ";"}], 
  RowBox[{"(*", "neposortiran", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cjisort", "=", 
   RowBox[{"cji", "[", 
    RowBox[{"[", 
     RowBox[{"red", "+", "1", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Join", "@@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "i"}], ",", "i"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "0", ",", "red"}], "}"}]}], "]"}]}], ")"}], "[", 
       RowBox[{"[", 
        RowBox[{"2", ";;"}], "]"}], "]"}]}], "    ", "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CHacek]leni", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"cji", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "1.0"}], 
           FractionBox[
            RowBox[{"n", " ", "2", "\[Pi]", " ", "\[ImaginaryI]", " ", "j"}], 
            "\[SHacek]togl2"], " "}]], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{"-", "red"}], ",", "red"}], "}"}]}], "]"}]}], ")"}], "[", 
     RowBox[{"[", 
      RowBox[{"red", "+", "1", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Join", "@@", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "i"}], ",", "i"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "0", ",", "red"}], "}"}]}], "]"}]}], ")"}], 
        "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;"}], "]"}], "]"}]}], "    ", "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", "posortiran", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"konice", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Total", "@", 
       RowBox[{"\[CHacek]leni", "[", 
        RowBox[{"[", 
         RowBox[{";;", "i"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{
         RowBox[{"2", "red"}], "+", "1"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"konicetkart", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Re", "[", "#1", "]"}], ",", 
          RowBox[{"Im", "[", "#1", "]"}]}], "}"}], "&"}], "/@", "konice"}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "\[SHacek]togl2"}], "}"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"ogli\[SHacek]\[CHacek]e", 
