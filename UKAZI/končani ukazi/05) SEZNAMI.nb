Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BinIndices1D", "[", 
     RowBox[{"vrednosti_", ",", "meje_"}], "]"}], ":=", 
    RowBox[{"(", "\n", "\t", 
     RowBox[{
      RowBox[{"bc", "=", 
       RowBox[{"BinCounts", "[", 
        RowBox[{"vrednosti", ",", 
         RowBox[{"{", "meje", "}"}]}], "]"}]}], ";", "\n", "\t", 
      RowBox[{"ord", "=", 
       RowBox[{"Ordering", "@", "vrednosti"}]}], ";", "\n", "\t", 
      RowBox[{
       RowBox[{
        RowBox[{"ord", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ";;", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "]"}], "&"}], "/@", 
       RowBox[{"(", "\n", "\t\t", 
        RowBox[{
         RowBox[{"Partition", "[", "\n", "\t\t\t", 
          RowBox[{
           RowBox[{"Prepend", "[", 
            RowBox[{
             RowBox[{"Accumulate", "@", "bc"}], ",", "0"}], "]"}], ",", "2", 
           ",", "1"}], "\n", "\t\t", "]"}], "+", 
         RowBox[{"Threaded", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}], ",", "2"}], "]"}]}], "\n", "\t", 
        ")"}]}]}], "\n", ")"}]}], ";"}], "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BinIndices", "[", 
     RowBox[{"to\[CHacek]ke_", ",", "mejeje_"}], "]"}], ":=", 
    RowBox[{"(", "\n", "\t", 
     RowBox[{
      RowBox[{"to\[CHacek]ketr", "=", 
       RowBox[{"to\[CHacek]ke", "\[Transpose]"}]}], ";", "\n", "\t", 
      RowBox[{"dim", "=", 
       RowBox[{"Length", "@", "to\[CHacek]ketr"}]}], ";", "\n", "\t", "\n", 
      "\t", "\n", "\t", 
      RowBox[{"binindjijiji", "=", 
       RowBox[{"Table", "[", "\n", "\t\t", 
        RowBox[{
         RowBox[{"BinIndices1D", "[", 
          RowBox[{
           RowBox[{"to\[CHacek]ketr", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"mejeje", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", "\n", "\t", 
         RowBox[{"{", 
          RowBox[{"i", ",", "dim"}], "}"}]}], "]"}]}], ";", "\n", "\t", "\n", 
      "\t", "\n", "\t", 
      RowBox[{"BloKoord", "=", 
       RowBox[{"Flatten", "[", "\n", "\t\t", 
        RowBox[{
         RowBox[{"CoordinateBoundsArray", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", 
              RowBox[{
               RowBox[{"Length", "@", "#"}], "-", "1"}]}], "}"}], "&"}], "/@",
            "mejeje"}], "]"}], ",", "\n", "\t\t", 
         RowBox[{"dim", "-", "1"}]}], "\n", "\t", "]"}]}], ";", "\n", "\t", 
      "\n", "\t", "\n", "\t", 
      RowBox[{
       RowBox[{"{", "\n", "\t\t", 
        RowBox[{"BloKoord", ",", "\n", "\t\t", "\n", "\t\t", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Intersection", "@@", "\n", "\t\t\t", 
             RowBox[{"Table", "[", "\n", "\t\t\t\t", 
              RowBox[{
               RowBox[{"binindjijiji", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "]"}], ",", "\n", 
               "\t\t\t", 
               RowBox[{"{", 
                RowBox[{"i", ",", "dim"}], "}"}]}], "]"}]}], "\n", "\t\t", 
            ")"}], "&"}], "/@", "BloKoord"}]}], "\n", "\t", "}"}], 
       "\[Transpose]"}]}], "\n", ")"}]}], ";"}], "\n", "\n", "\n", "\n", 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"to\[CHacek]ke", "=", 
