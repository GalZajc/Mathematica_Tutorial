Cell[BoxData[{
 RowBox[{
  RowBox[{"Nto\[CHacek]k", "=", "10000"}], ";", " ", 
  RowBox[{"R", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[CurlyPhi]ji", "=", 
   RowBox[{"\[Pi]", " ", 
    RowBox[{"Subdivide", "[", 
     RowBox[{
      RowBox[{"-", "1."}], ",", "1.", ",", "Nto\[CHacek]k"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zji", "=", 
   RowBox[{
    SuperscriptBox["\[CurlyPhi]ji", "2"], "+", 
    RowBox[{".2", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"100", " ", "\[CurlyPhi]ji"}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"xji", ",", "yji"}], "}"}], "=", 
   RowBox[{"R", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "@", "\[CurlyPhi]ji"}], ",", 
      RowBox[{"Sin", "@", "\[CurlyPhi]ji"}]}], "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rji3D", "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xji", ",", "yji", ",", "zji"}], "}"}], "\[Transpose]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"ListLinePlot3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rji3D", ",", 
     RowBox[{"MovingAverageCik", "[", 
      RowBox[{"rji3D", ",", 
       RowBox[{"Round", "[", 
        RowBox[{".1", " ", "Nto\[CHacek]k"}], "]"}]}], "]"}]}], "}"}], ",", 
   RowBox[{"BoxRatios", "->", "2"}]}], "]"}]}], "Code",
