  FractionBox["1", 
   RowBox[{"2", "\[Pi]"}]], 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"f", "[", "t", "]"}], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], " ", "\[Omega]", " ", "t"}]]}], ")"}], 
