Cell[TextData[{
 StyleBox["Za jemat z rezervo to poglavje: to se lah \[CHacek]ist spremeni v \
prihodnosti !!!!!!!!!!!!!!!!!!\n",
  FontSize->24,
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontVariations->{"Underline"->True}],
 StyleBox["Z ",
  FontSize->24],
 StyleBox["rde\[CHacek]o",
  FontSize->24,
  FontColor->RGBColor[1, 0, 0]],
 StyleBox[" so stvari, k se jih ves \[CHacek]as uporablja\nZ ",
  FontSize->24],
 StyleBox["rumeno",
  FontSize->24,
  FontColor->RGBColor[1, 1, 0]],
 StyleBox[" so stvari, k se jih sm pa tja uporablja",
  FontSize->24]
}], "Text",
 CellChangeTimes->{{3.8698786803701677`*^9, 3.8698787087938857`*^9}, {
