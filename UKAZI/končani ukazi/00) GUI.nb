Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       StyleBox["f", "TI"], 
       RowBox[{"(", "\[Omega]", ")"}], "\[LongEqual]", 
       FractionBox["1", 
        SqrtBox[
         RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"1", "-", 
                SuperscriptBox["\[Xi]", "2"]}], ")"}], "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
              FractionBox[
               RowBox[{"2", "\[Beta]"}], 
               SubscriptBox["\[Omega]", "0"]], ")"}], "2"], 
           SuperscriptBox["\[Xi]", "2"]}]]], "\[NegativeThinSpace] ", "."}], 
     TraditionalForm], "errors" -> {}, "input" -> 
