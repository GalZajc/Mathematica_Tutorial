Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PloskveVOglInd", "[", "Ploskve_", "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"OAssI", "=", 
       RowBox[{"Association", "[", "]"}]}], ";", "\n", "\t", 
      RowBox[{"ind", "=", "0"}], ";", "\n", "\t", 
      RowBox[{"indjiji", "=", 
       RowBox[{"Map", "[", "\n", "\t\t", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"KeyExistsQ", "[", 
             RowBox[{"OAssI", ",", "#"}], "]"}], ",", "\n", "\t\t\t", 
            RowBox[{"OAssI", "[", "#", "]"}], ",", "\n", "\t\t\t", 
            RowBox[{
             RowBox[{"ind", "++"}], ";", " ", 
             RowBox[{
              RowBox[{"OAssI", "[", "#", "]"}], "=", "ind"}], ";", " ", 
             "ind"}]}], " ", "\n", "\t\t", "]"}], "&"}], ",", " ", "Ploskve", 
         ",", " ", 
         RowBox[{"{", "2", "}"}]}], "\n", "\t", "]"}]}], ";", "\n", "\t", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Keys", "@", "OAssI"}], ",", "indjiji"}], "}"}]}], 
     "\[IndentingNewLine]", ")"}]}], ";"}], "\n"}], "\n", 
