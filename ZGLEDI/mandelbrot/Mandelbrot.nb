   "*******)"}]}], "\n", 
 RowBox[{
  RowBox[{"mapa", "=", 
   RowBox[{"NotebookDirectory", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"xmin", ",", "xmax"}], "}"}], "=", 
   RowBox[{"N", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "2.0"}], ",", ".5"}], "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ymin", ",", "ymax"}], "}"}], "=", 
   RowBox[{"N", "@", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1.0"}], "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resx", "=", "1920"}], ";", " ", 
  RowBox[{"resy", "=", 
   RowBox[{"Round", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"ymax", "-", "ymin"}], 
      RowBox[{"xmax", "-", "xmin"}]], "resx"}], "]"}]}], ";", " ", 
  RowBox[{"res", "=", 
   RowBox[{"{", 
    RowBox[{"resx", ",", "resy"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"korakov", "=", "500"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"z0", "=", 
   RowBox[{"0.0", "+", 
    RowBox[{"0.0", "\[ImaginaryI]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "zjiji_", "]"}], ":=", 
    RowBox[{
     SuperscriptBox["zjiji", "2"], "+", "cjiji"}]}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**",
     "PODATKI", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**"}], 
   "*******)"}], "\n", "\n", "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{"cjiji", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"x", "+", 
      RowBox[{"y", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "xmin", ",", "xmax", ",", 
       FractionBox[
        RowBox[{"xmax", "-", "xmin"}], 
        RowBox[{"resx", "-", "1"}]]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "ymax", ",", "ymin", ",", 
       FractionBox[
        RowBox[{"ymin", "-", "ymax"}], 
        RowBox[{"resy", "-", "1"}]]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"zjiji", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"z0", ",", "res"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"notri", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"1", ",", "res"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"notriVsota", "=", 
   RowBox[{"0.0", " ", "notri"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SystemOpen", "@", "mapa"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", "\n", "\t", 
   RowBox[{
    RowBox[{
     RowBox[{"zjiji", "=", 
      RowBox[{"f", "@", "zjiji"}]}], ";", "\n", "\t", 
     RowBox[{"notri", "*=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1.0", "+", 
         RowBox[{"Sign", "[", 
          RowBox[{"2.0", "-", 
           RowBox[{"Abs", "@", "zjiji"}]}], "]"}]}], ")"}], "/", "2.0"}]}], 
     ";", "\n", "\t", 
     RowBox[{"zjiji", "*=", "notri"}], ";", "\n", "\t", 
     RowBox[{"notriVsota", "+=", "notri"}], ";", "\n", "\t", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"IntegerQ", "[", 
        RowBox[{"i", "/", "10"}], "]"}], ",", 
       RowBox[{"Print", "[", "i", "]"}]}], "]"}], ";", "\n", "\t", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"IntegerQ", "[", 
        RowBox[{"i", "/", "100"}], "]"}], ",", 
       RowBox[{
        RowBox[{"Export", "[", 
         RowBox[{
          RowBox[{"mapa", " ", "<>", " ", 
           RowBox[{"ToString", "[", "i", "]"}], " ", "<>", " ", 
           "\"\<iteracij.png\>\""}], ",", 
          RowBox[{"Image", "@", 
           RowBox[{"Transpose", "@", 
            FractionBox["notriVsota", "i"]}]}]}], "]"}], ";"}]}], "]"}]}], 
    ",", "\n", 
    RowBox[{"{", 
     RowBox[{"i", ",", "korakov"}], "}"}]}], "]"}], ";"}]}], "Code",
