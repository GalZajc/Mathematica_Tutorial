Notebook[{

Cell[CellGroupData[{
Cell["15. NALOGA: NEZNANI VRTE\[CapitalCHacek]I PREDMET", "Title",
 CellChangeTimes->{{3.8732821285054655`*^9, 
  3.8732821493780622`*^9}},ExpressionUUID->"7c0dee9e-d9dd-4457-a6be-\
8445deca646d"],

Cell["NALOGA", "Subtitle",
 CellChangeTimes->{{3.873282174752755*^9, 
  3.8732821799299364`*^9}},ExpressionUUID->"5c995806-db80-4a8f-995f-\
cc552eb197a1"],

Cell[TextData[{
 "Dan je posnetek  video, neznanega vrte\[CHacek]ega predmeta (NVP). Posnet \
je v fps slikah na sekundo. Poi\[SHacek]\[CHacek]i lokalno maksimalne \
velikosti kotne hitrosti NVP-ja.\n Za re\[SHacek]itev naloge se\[SHacek]tej \
te kotne hitrosti in to zaokro\[ZHacek]i na ",
 Cell[BoxData[
  FormBox[
   RowBox[{"15", 
    SuperscriptBox["s", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b483af1a-f9af-47e8-bc68-87a7e7cb2908"],
 ". Eksperimentiraj, pomagaj si z ListLinePlot."
}], "Text",
 CellChangeTimes->{{3.873284960803858*^9, 
  3.8732850206191015`*^9}},ExpressionUUID->"591474c1-1e80-4109-9c16-\
a3119da39f4c"],

Cell[CellGroupData[{

Cell["RE\[CapitalSHacek]EVANJE", "Subtitle",
 CellChangeTimes->{{3.873284054320921*^9, 
  3.8732840567199306`*^9}},ExpressionUUID->"83314cf5-f415-4cb9-9c65-\
6353842e2971"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Remove", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"fps", "=", "60"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"video", "=", 
    RowBox[{"Video", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], "<>", 
      "\"\<znani vrte\[CHacek]i predmet.mp4\>\""}], "]"}]}], ";"}], "\n", 
