d087056b0723"],

Cell[CellGroupData[{

Cell[TextData[{
 "Pozor: txt datoteke imajo lahko na koncu prazno vrstico, ki jo je treba \
tudi upo\[SHacek]tevati. Uporabi ",
 StyleBox["ImportTxt",
  FontWeight->"Bold"],
 " za uvoz txt datotek. "
}], "Item",
 CellChangeTimes->{{3.87266003825618*^9, 3.872660140352353*^9}, {
  3.872660173642337*^9, 3.872660215288407*^9}, {3.8726603083439083`*^9, 
  3.8726603299863*^9}},ExpressionUUID->"c10897e2-7912-470d-9924-d148f19ea0f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Remove", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ImportTxt", "[", "file_", "]"}], ":=", 
   RowBox[{"StringJoin", "@", 
    RowBox[{"StringRiffle", "[", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ImportString", "[", 
         RowBox[{"#", ",", " ", "\"\<Text\>\""}], "]"}], " ", "&"}], " ", "/@", 
       RowBox[{"StringSplit", "[", "\n", "\t\t", 
        RowBox[{
         RowBox[{"Import", "[", 
          RowBox[{"file", ",", "\"\<String\>\""}], "]"}], ",", "\n", "\t\t", 
         "\"\<\\n\>\"", ",", " ", "All"}], "\n", "\t", "]"}]}], ",", "\n", 
      "\t", "\"\<\\n\>\""}], "\n", "]"}]}]}], ";"}]}], "Code",
 CellChangeTimes->{
  3.8726602908918366`*^9, {3.8726610750449624`*^9, 3.872661086623352*^9}},
 CellLabel->
  "In[1160]:=",ExpressionUUID->"799230e5-33ce-4d67-b392-9b050704b5ee"]
}, Open  ]],

Cell[TextData[{
 "Za pretvorbo rimskih \[SHacek]tevilk v Integerje lahko uporabi\[SHacek] \
vgrajeno funkcijo ",
 StyleBox["FromRomanNumeral",
  FontWeight->"Bold"],
 ", je pa tudi dobra dodatna vaja iz stringov, \[CHacek]e sam sprogramira\
\[SHacek]."
}], "Item",
 CellChangeTimes->{{3.8726603548561935`*^9, 
  3.8726605119289093`*^9}},ExpressionUUID->"fc1847cf-2e96-4def-ab69-\
1612fd76f236"],

