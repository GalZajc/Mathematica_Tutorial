Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Remove", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"s", "=", 
    RowBox[{"Import", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], "<>", "\"\<slika.png\>\""}], 
     "]"}]}], ";"}], "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"RID", ",", "GID", ",", "BID", ",", "\[Alpha]ID"}], "}"}], "=", 
    RowBox[{"Transpose", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"ImageData", "@", "s"}], ",", "\n", 
      RowBox[{"InversePermutation", "@", 
       RowBox[{"{", 
        RowBox[{"3", ",", "1", ",", "2"}], "}"}]}]}], "]"}]}], ";"}], "\n", 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"-", "1"}], "+", 
  RowBox[{"Count", "[", "\n", "\t", 
   RowBox[{
    RowBox[{"DeleteAdjacentDuplicates", "@", "\n", "\t\t", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"RID", "[", 
        RowBox[{"[", 
         RowBox[{";;", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{"RID", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"-", "1"}], ",", ";;"}], "]"}], "]"}]}], "]"}]}], ",", "\n",
     "0."}], "]"}], "+", "\n", "\n", 
  RowBox[{"Length", "@", 
   RowBox[{"DeleteDuplicates", "@", 
    RowBox[{"Flatten", "@", "GID"}]}]}], "+", "\n", "\n", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"KordE", "=", 
     RowBox[{"Position", "[", 
      RowBox[{
       RowBox[{"Round", "@", "BID"}], ",", "0"}], "]"}]}], ";", "\n", 
    RowBox[{"RazdOdSred", "=", 
     RowBox[{"Norm", "/@", 
      RowBox[{"(", 
       RowBox[{"KordE", "-", 
        RowBox[{"Threaded", "[", 
         RowBox[{
          RowBox[{"N", "@", 
           RowBox[{"Mean", "@", "KordE"}]}], ",", "2"}], "]"}]}], ")"}]}]}], 
    ";", "\n", 
    RowBox[{"Round", "@", 
     FractionBox[
      RowBox[{"Max", "@", "RazdOdSred"}], 
      RowBox[{"Min", "@", "RazdOdSred"}]]}]}], ")"}], "+", "\n", "\n", 
  RowBox[{"Mean", "@", 
   RowBox[{"Mean", "@", "\[Alpha]ID"}]}], "+", "\n", 
  RowBox[{"StandardDeviation", "@", 
   RowBox[{"Flatten", "@", "\[Alpha]ID"}]}]}]}], "Code",
