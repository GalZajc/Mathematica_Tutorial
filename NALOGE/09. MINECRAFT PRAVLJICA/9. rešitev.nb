 RowBox[{
  RowBox[{"indr", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rAssI", "=", 
   RowBox[{"<|", 
    RowBox[{"1", "->", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "|>"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
