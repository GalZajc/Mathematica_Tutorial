        "__", "~~", "\"\< in \>\"", "~~", "SmerNPred__", "~~", "\"\<prej\>\"",
          "~~", "__"}], ")"}], "->", "SmerNPred"}]}], "\n", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
