Cell["NALOGA", "Subtitle",
 CellChangeTimes->{{3.8730166105908213`*^9, 
  3.8730166116856775`*^9}},ExpressionUUID->"c2511a87-121d-4ba3-998f-\
bcb2222d5fa4"],

Cell[TextData[{
 "Trije zubati v Seafoamski jami sli\[SHacek]ijo articunota. Kar \
sli\[SHacek]ijo je shranjeno v spremenljivki ",
 StyleBox["zvoki",
  FontWeight->"Bold"],
 " . Njihova u\[SHacek]esa {levo, desno} so takrat v to\[CHacek]kah  ",
 StyleBox["rjijiU",
  FontWeight->"Bold"],
 ". Hitrost zvoka v jami je c. Kako visoko je articuno (kljun)? \
Re\[SHacek]itev naj  bo zaokro\[ZHacek]ena na 10m."
}], "Text",
 CellChangeTimes->{{3.8730161715091653`*^9, 3.8730162213174405`*^9}, {
