  3.8733000106531525`*^9}},ExpressionUUID->"cd40edfb-98c4-4d23-88c4-\
857bdcb28fb4"],

Cell[TextData[{
 "Skrito sporo\[CHacek]ilo uganke ",
 StyleBox["NI",
  FontWeight->"Bold"],
 " metafori\[CHacek]no, ko bo\[SHacek] razvozlal/a uganko, bo\[SHacek] to \
vedel/a, brez dvoma. "
}], "Item",
 CellChangeTimes->{{3.8733000149498987`*^9, 3.873300047396861*^9}, {
  3.8733011787239895`*^9, 
  3.873301193251998*^9}},ExpressionUUID->"2741bfc4-fccf-4e44-8f2a-\
7a9114bee80c"],

Cell["\<\
Razvozlavanje je dolgo okoli 5 vrstic kode. \[CapitalCHacek]e jih \
ima\[SHacek] nad 10, si zelo verjetno na napa\[CHacek]ni poti.\
\>", "Item",
 CellChangeTimes->{{3.8733000149498987`*^9, 3.8733000317311554`*^9}, {
   3.873300095411289*^9, 3.873300209459019*^9}, 
   3.873300833892583*^9},ExpressionUUID->"2cdd2cd5-92aa-41e4-99b5-\
71e87e2b2dc8"],

Cell["\<\
Ne rabi\[SHacek] nobenih posebnih ukazev. Rabi\[SHacek] samo znanje o \
arraysih.\
\>", "Item",
 CellChangeTimes->{{3.8733000149498987`*^9, 3.8733000317311554`*^9}, {
  3.873300095411289*^9, 3.873300307451289*^9}, {3.8733004077130027`*^9, 
  3.873300407719126*^9}},ExpressionUUID->"d1b1f0ee-eab7-4dca-b100-\
14ab1bb630ac"],

Cell[TextData[StyleBox["Pri re\[SHacek]evanju bo\[SHacek] neko stvar, ki je \
med 0 in 1, ponekod  povpre\[CHacek]il/a in to preslikal/a med -500 in 500",
 FontWeight->"Bold"]], "Item",
 CellChangeTimes->{{3.8733000149498987`*^9, 3.8733000317311554`*^9}, {
  3.873300095411289*^9, 3.873300307451289*^9}, {3.873300417373437*^9, 
  3.8733005593253613`*^9}, {3.8733006002808*^9, 3.8733006002878*^9}, {
  3.8733014718219056`*^9, 
  3.8733015167038116`*^9}},ExpressionUUID->"8993bfee-0da6-4203-8b8d-\
782701c91f70"],

Cell["\<\
Spodaj je nekaj namigov. \[CapitalCHacek]e no\[CHacek]e\[SHacek] biti \
spoilan/a, jih ne beri. \
\>", "Item",
 CellChangeTimes->{{3.8733000149498987`*^9, 3.8733000317311554`*^9}, {
  3.873300095411289*^9, 3.873300307451289*^9}, {3.873300417373437*^9, 
