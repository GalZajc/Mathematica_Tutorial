Cell[TextData[{
 "Po\[ZHacek]eni celico in dobil/a bo\[SHacek] sliko ",
 StyleBox["s",
  FontWeight->"Bold"],
 ". Slika ",
 StyleBox["s",
  FontWeight->"Bold"],
 " skriva super skrivno sporo\[CHacek]ilo."
}], "Text",
