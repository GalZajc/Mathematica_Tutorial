Cell[TextData[{
 "\[CapitalZHacek]aba \[ZHacek]ivi v 2D, sedi na lokvanju v to\[CHacek]ki ",
 StyleBox["r0",
  FontWeight->"Bold"],
 " in se obra\[CHacek]a proti muhi. Muha najprej leti v ravnih \[CHacek]rtah \
med zaporednimi  to\[CHacek]kami ",
 StyleBox["pot",
  FontWeight->"Bold"],
 ", na koncu pa se vrne v za\[CHacek]etno to\[CHacek]ko poti.  \nKoliko \
obratov, nasproti smeri urinega kazalca naredi \[ZHacek]aba, ko muha preleti \
pot? "
}], "Text",
