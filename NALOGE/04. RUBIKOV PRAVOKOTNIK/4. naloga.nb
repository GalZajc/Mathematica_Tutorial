}], "Item",
 CellChangeTimes->{{3.873219997645348*^9, 
  3.873220008008006*^9}},ExpressionUUID->"fef667d3-da08-42a0-8f4f-\
64a323e6a569"],

Cell[TextData[{
 "1. stolpec od ",
 StyleBox["premiki",
  FontWeight->"Bold"],
 " je 1, \[CHacek]e vrtimo vrstico in 2, \[CHacek]e vrtimo stolpec RP."
}], "Item",
 CellChangeTimes->{{3.873219997645348*^9, 3.873220022534212*^9}, 
