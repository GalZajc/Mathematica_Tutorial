Cell[TextData[{
 "3. stolpec od ",
 StyleBox["premiki",
  FontWeight->"Bold"],
 " pove za koliko polj zavrtimo. Pozitivni smeri sta desno in dol."
}], "Item",
 CellChangeTimes->{{3.873219997645348*^9, 3.8732200630394983`*^9}, {
