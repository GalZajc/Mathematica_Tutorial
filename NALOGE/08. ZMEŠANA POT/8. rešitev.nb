Cell["\<\
posortiran mamo v neko smer, ne vemo pa \[CHacek]e je taprava. 
Vzamemo to\[CHacek]ki blizu, na nasprotnih straneh sredine recimo prve \
stranice.
Ena od teh to\[CHacek]k je znotrej poti. Obrat okoli te to\[CHacek]ke nam \
pove orientacijo.\
\>", "Text",
 CellChangeTimes->{
  3.8728441105948763`*^9},ExpressionUUID->"5ffbf74d-e9ab-4de7-94fb-\
d6aa89ccf7db"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Obrati", "[", 
     RowBox[{"pot_", ",", "to\[CHacek]ka_"}], "]"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", "\[Pi]"}]], 
     RowBox[{"(", "\n", "\t", 
      RowBox[{
       RowBox[{"\[CapitalDelta]pot", "=", 
        RowBox[{"pot", "-", 
         RowBox[{"Threaded", "[", 
          RowBox[{"to\[CHacek]ka", ",", "2"}], "]"}]}]}], ";", "\n", "\t", 
       "\n", "\t", 
       RowBox[{"Total", "@", 
        RowBox[{
         RowBox[{"(", "\[IndentingNewLine]", "\t", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"ToPolarCoordinates", "[", "\n", "\t\t", 
              RowBox[{
               RowBox[{"RotationMatrix", "[", 
                RowBox[{"-", 
                 RowBox[{
                  RowBox[{"ToPolarCoordinates", "[", "#1", "]"}], "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ".", "#2"}], "\n", 
              "\t", "]"}], "&"}], ")"}], "@@@", "\n", "\t", 
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"N", "@", "\[CapitalDelta]pot"}], ",", 
              RowBox[{"RotateLeft", "@", "\[CapitalDelta]pot"}]}], "}"}], 
            "]"}]}], "\n", "\t", ")"}], "[", 
         RowBox[{"[", 
          RowBox[{";;", ",", "2"}], "]"}], "]"}]}]}], "\n", ")"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Orientacija", "[", "pot_", "]"}], ":=", 
    RowBox[{"(", "\n", "\t", 
     RowBox[{
      RowBox[{"to\[CHacek]ki", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", "\n", "\t\t", 
          RowBox[{
           RowBox[{"Mean", "@", 
            RowBox[{"pot", "[", 
             RowBox[{"[", 
              RowBox[{";;", "2"}], "]"}], "]"}]}], " ", "+", " ", "\n", 
           "\t\t", 
           RowBox[{
            RowBox[{"RotationMatrix", "[", "#", "]"}], ".", 
            RowBox[{"(", 
             RowBox[{".0001", 
              RowBox[{"Normalize", "[", 
               RowBox[{
                RowBox[{"pot", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "-", 
                RowBox[{"pot", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ")"}]}]}], "\n", 
          "\t", ")"}], "&"}], "/@", 
        RowBox[{"{", 
         RowBox[{
          FractionBox["\[Pi]", "2"], ",", 
          RowBox[{"-", 
           FractionBox["\[Pi]", "2"]}]}], "}"}]}]}], ";", "\n", "\t", 
      RowBox[{"Sign", "@", 
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Obrati", "[", 
           RowBox[{"pot", ",", "#"}], "]"}], "&"}], "/@", "to\[CHacek]ki"}], 
        "]"}]}]}], "\n", ")"}]}], ";"}], "\n", "\n"}], "\n", 
 RowBox[{"pos", "[", 
  RowBox[{"[", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Orientacija", "[", "pos", "]"}], " ", "==", " ", "1"}], ",", 
      " ", "Nto\[CHacek]k", ",", " ", 
      RowBox[{
       RowBox[{"-", "Nto\[CHacek]k"}], "+", "1"}]}], "]"}], ",", "1"}], "]"}],
   "]"}]}], "Code",
