Cell[TextData[{
 "Mejne ploskve skulptur so podane v seznamu ",
 StyleBox["Ploskvekve",
  FontWeight->"Bold"],
 ". Vsak element iz ",
 StyleBox["Ploskvekve",
  FontWeight->"Bold"],
 " je seznam mejnih ploskev ene skulpture. Vsaka ploskev je podana kot seznam \
ogli\[SHacek]\[CHacek].\nKoliko skulptur se podre, \[CHacek]e jih postavimo \
na ravna tla? \[CapitalCHacek]e je skulptura na meji tega, da se podre, potem \
se podre.\nPomagaj si s poglavjem \[OpenCurlyDoubleQuote]\[CapitalSHacek]E \
NEKAJ O MESHIH\[CloseCurlyDoubleQuote] iz:"
}], "Text",
 CellChangeTimes->{{3.873126080959728*^9, 3.8731261180737114`*^9}, {
  3.8731261579361115`*^9, 3.8731264435498557`*^9}, {3.8731264940448675`*^9, 
